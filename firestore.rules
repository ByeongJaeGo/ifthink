rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: eventEntries/{uid}
    // - uid: string (must match auth.uid)
    // - nickname: string (2-20 chars)
    // - email: string (valid email)
    // - createdAt: timestamp
    // - updatedAt: timestamp
    // - source: string ("starbucks_week")
    // - scenarioId: string | null (optional)
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidEmail(email) {
      return email is string
        && email.size() >= 5
        && email.size() <= 120
        && email.matches('.*@.*\\..*');
    }

    function isValidEventEntry() {
      let d = request.resource.data;
      return d.keys().hasOnly(['uid', 'nickname', 'email', 'createdAt', 'updatedAt', 'source', 'scenarioId'])
        && d.uid is string
        && d.uid == request.auth.uid
        && d.nickname is string
        && d.nickname.size() >= 2
        && d.nickname.size() <= 20
        && isValidEmail(d.email)
        && d.createdAt is timestamp
        && d.updatedAt is timestamp
        && d.source == 'starbucks_week'
        && (d.scenarioId == null || (d.scenarioId is string && d.scenarioId.size() <= 80));
    }

    match /eventEntries/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidEventEntry()
        && request.resource.data.createdAt == request.time;
      allow update: if isOwner(uid) && isValidEventEntry()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }
  }
}
