rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: eventEntries/{uid}
    // - uid, nickname, email, createdAt, updatedAt, source, scenarioId?
    // - eventTickets?: number
    //
    // Collection: userNotifications/{uid}/items/{itemId}
    // - toUid, fromUid, fromNick, type ("play"|"comment")
    // - scenarioId, scenarioText, commentText?, read, createdAt, createdAtMs
    //
    // Collection: nicknames/{nickKey}
    // - uid, nickname, updatedAt, createdAt
    // - nickKey = lowercased trimmed nickname (unique)
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidEmail(email) {
      return email is string
        && email.size() >= 5
        && email.size() <= 120
        && email.matches('.*@.*\\..*');
    }

    function isValidEventEntry() {
      let d = request.resource.data;
      return d.keys().hasOnly(['uid', 'nickname', 'email', 'createdAt', 'updatedAt', 'source', 'scenarioId', 'eventTickets'])
        && d.uid is string
        && d.uid == request.auth.uid
        && d.nickname is string
        && d.nickname.size() >= 2
        && d.nickname.size() <= 20
        && isValidEmail(d.email)
        && d.createdAt is timestamp
        && d.updatedAt is timestamp
        && d.source == 'starbucks_week'
        && (d.scenarioId == null || (d.scenarioId is string && d.scenarioId.size() <= 80))
        && d.eventTickets is int
        && d.eventTickets >= 0
        && d.eventTickets <= 100000;
    }

    function isValidNotificationCreate(uid) {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'toUid', 'fromUid', 'fromNick', 'type',
          'scenarioId', 'scenarioText', 'commentText',
          'read', 'createdAt', 'createdAtMs'
        ])
        && d.toUid == uid
        && d.fromUid == request.auth.uid
        && d.fromUid != d.toUid
        && d.fromNick is string
        && d.fromNick.size() >= 1
        && d.fromNick.size() <= 20
        && (d.type == 'play' || d.type == 'comment')
        && d.scenarioId is string
        && d.scenarioId.size() >= 1
        && d.scenarioId.size() <= 80
        && d.scenarioText is string
        && d.scenarioText.size() <= 120
        && (d.commentText == null || (d.commentText is string && d.commentText.size() <= 200))
        && d.read == false
        && d.createdAt is timestamp
        && d.createdAtMs is int;
    }

    function isValidNicknameDoc() {
      let d = request.resource.data;
      return d.keys().hasOnly(['uid', 'nickname', 'createdAt', 'updatedAt'])
        && d.uid == request.auth.uid
        && d.nickname is string
        && d.nickname.size() >= 2
        && d.nickname.size() <= 20
        && d.createdAt is timestamp
        && d.updatedAt is timestamp;
    }

    match /eventEntries/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidEventEntry()
        && request.resource.data.createdAt == request.time;
      allow update: if isOwner(uid) && isValidEventEntry()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /userNotifications/{uid}/items/{itemId} {
      allow read: if isOwner(uid);
      allow create: if isSignedIn() && isValidNotificationCreate(uid)
        && request.resource.data.createdAt == request.time;
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read is bool
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.fromUid == resource.data.fromUid;
      allow delete: if isOwner(uid);
    }

    match /nicknames/{nickKey} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && isValidNicknameDoc()
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && isValidNicknameDoc()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
